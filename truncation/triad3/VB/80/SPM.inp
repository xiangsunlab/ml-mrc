## Settings for MSH model
system_type              model                                              # model system
MSH_type                 I                                                  # MSH-I model
DOFe                     4                                                  # number of states
DOFn                     600                                                # total nuclear DOF = N*(DOFe-1)
energy_unit              eV                                                 # unit of energy parameter in this file
epsilon                  0.0,-0.82822952,-0.640085896,0.0                   # minimum energy of each states
gamma_DA                 -0.01467393,0.007201061,0.0,-0.02924042,0.0,0.0    # dibatic coupling, the order is gamma_01,02,12
model_load               /gpfsnyu/xspace/projects/TT-dyn/Jobs/MLMRC/Models/triad3/shifts.csv # load the model parameters (frequencies and shifts) from file

## Settings for dynamcis
nucl_sample              Wigner                                            
temperature              300                                                # temperature (in K) for nuclear sampling
sample_state             3                                                  # sampling state
init_state               0,0                                                # dynamics start from population state 0
nsteps                   10000                                              # total nuclear steps to run
DT                       0.001                                              # time step size in ps
ntraj                    10000                                              # total number of trajectory to run
EPN                      20                                                 # electronic steps per nuclear step
min_judge_traj_avail     1                                                 

## Additional

## Auto Scan
model_type               MLMRC
MLMRC_layer              -1
MLMRC_picture            VB
N_truncation             80
dyn_type                 SPM

