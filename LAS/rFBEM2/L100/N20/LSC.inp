
## tuned multi-state harmonic (tMSH) model

## Settings for MSH model
system_type              model                                              # model system
model_type               MLMRC                                              # MSH model
MSH_type                 I                                                  # MSH-I model
DOFe                     3                                                  # number of states
DOFn                     200                                                # total nuclear DOF = N*(DOFe-1)
energy_unit              cm-1                                               # unit of energy parameter in this file
epsilon                  0.0,50.0,-50.0                                     # minimum energy of each states
gamma_DA                 0.0,0.0,100.0                                      # dibatic coupling, the order is gamma_01,02,12
model_load               /gpfsnyu/xspace/projects/TT-dyn/Jobs/MLMRC/Models/rFBEM2/shifts.csv # load the model parameters (frequencies and shifts) from file

## Settings for dynamcis
dyn_type                 LSC                                                # dynamical method
nucl_sample              Wigner                                            
temperature              72                                                 # temperature (in K) for nuclear sampling
#beta                                                                        # 1/kT for nuclear sampling
sample_state             0                                                  # sampling state
init_state               all                                                # dynamics start from population state 0
nsteps                   20000                                              # total nuclear steps to run
DT                       0.0001                                             # time step size in ps
ntraj                    10000                                              # total number of trajectory to run
EPN                      20                                                 # electronic steps per nuclear step
min_judge_traj_avail     1                                                 

## Additional
MLMRC_layer              100                                                # L=1 star-like, L=N chain-like, 1<L<N arrow-like
MLMRC_picture            CL                                                 # CL/VB picture for truncation
N_truncation             20                                                 # Nt=1 RC-only, Nt=N exact, 1<=Nt<N tML-MRC
